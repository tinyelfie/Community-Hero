    let isSheetOpen = false;

    function toggleBottomSheet() {
        const sheet = document.getElementById('bottom-sheet');
        if (isSheetOpen) {
            sheet.style.transform = 'translateY(calc(530px - 140px))';
            if (window.innerWidth >= 768) sheet.style.transform = 'translateY(calc(530px - 160px))';
        } else {
            sheet.style.transform = 'translateY(0)';
        }
        isSheetOpen = !isSheetOpen;
    }

    function openIssueDetail(title) {
        const drawer = document.getElementById('issue-detail-drawer');
        const titleEl = document.getElementById('detail-title');
        titleEl.innerText = title;
        drawer.style.transform = 'translateX(0)';
    }

    function closeIssueDetail() {
        const drawer = document.getElementById('issue-detail-drawer');
        drawer.style.transform = 'translateX(100%)';
    }

    // Parallax map interaction
    document.addEventListener('mousemove', (e) => {
        const x = (window.innerWidth / 2 - e.pageX) / 120;
        const y = (window.innerHeight / 2 - e.pageY) / 120;
        const map = document.querySelector('[data-location]');
        if(map) {
            map.style.transform = `scale(1.1) translate(${x}px, ${y}px)`;
            map.style.transition = 'transform 0.3s ease-out';
        }
    });

    window.addEventListener('resize', () => {
        if (isSheetOpen) {
            document.getElementById('bottom-sheet').style.transform = 'translateY(0)';
        } else {
             const sheet = document.getElementById('bottom-sheet');
             sheet.style.transform = window.innerWidth >= 768 ? 'translateY(calc(530px - 160px))' : 'translateY(calc(530px - 140px))';
        }
    });
</script>
